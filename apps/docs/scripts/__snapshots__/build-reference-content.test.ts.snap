      "@supabase/auth-js.GoTrueAdminApi.listUsers": {
        "comment": {
          "examples": [
            {
              "code": "\`\`\`js
const { data: { users }, error } = await supabase.auth.admin.listUsers()
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "get-a-page-of-users",
              "name": "Get a page of users",
              "response": undefined,
            },
            {
              "code": "\`\`\`js
const { data: { users }, error } = await supabase.auth.admin.listUsers({
  page: 1,
  perPage: 1000
})
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "paginated-list-of-users",
              "name": "Paginated list of users",
              "response": undefined,
            },
          ],
          "shortText": "Get a list of users.

This function should only be called on a server. Never expose your \`service_role\` key in the browser.",
          "text": "- Defaults to return 50 users per page.",
        },
        "name": "@supabase/auth-js.GoTrueAdminApi.listUsers",
        "params": [
          {
            "comment": {
              "shortText": "An object which supports \`page\` and \`perPage\` as numbers, to alter the paginated results.",
            },
            "isOptional": true,
            "name": "params",
            "type": {
              "name": "PageParams",
              "properties": [
                {
                  "comment": {
                    "shortText": "The page number",
