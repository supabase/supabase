      "@supabase/auth-js.GoTrueAdminMFAApi.deleteFactor": {
        "comment": {
          "examples": [
            {
              "code": "\`\`\`js
const { data, error } = await supabase.auth.admin.mfa.deleteFactor({
  id: '34e770dd-9ff9-416c-87fa-43b31d7ef225',
  userId: 'a89baba7-b1b7-440f-b4bb-91026967f66b',
})
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "delete-a-factor-for-a-user",
              "name": "Delete a factor for a user",
              "response": "\`\`\`json
{
  data: {
    id: '34e770dd-9ff9-416c-87fa-43b31d7ef225'
  },
  error: null
}
\`\`\`",
            },
          ],
          "shortText": "Deletes a factor on a user. This will log the user out of all active
sessions if the deleted factor was verified.",
        },
        "name": "@supabase/auth-js.GoTrueAdminMFAApi.deleteFactor",
        "params": [
          {
            "name": "params",
            "type": {
              "name": "AuthMFAAdminDeleteFactorParams",
              "properties": [
                {
                  "comment": {
                    "shortText": "ID of the MFA factor to delete.",
                  },
                  "name": "id",
                  "type": {
                    "name": "string",
                    "type": "intrinsic",
                  },
                },
                {
                  "comment": {
                    "shortText": "ID of the user whose factor is being deleted.",
                  },
                  "name": "userId",
                  "type": {
                    "name": "string",
                    "type": "intrinsic",
                  },
                },
              ],
              "type": "object",
            },
          },
        ],
        "ret": {
          "type": {
            "awaited": {
              "name": "AuthMFAAdminDeleteFactorResponse",
              "subTypes": [
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "name": Symbol(anonymous),
                        "properties": [
                          {
                            "comment": {
                              "shortText": "ID of the factor that was successfully deleted.",
                            },
                            "name": "id",
                            "type": {
                              "name": "string",
                              "type": "intrinsic",
                            },
                          },
                        ],
                        "type": "object",
                      },
                    },
                    {
                      "name": "error",
                      "type": {
                        "type": "literal",
                        "value": null,
                      },
                    },
                  ],
                  "type": "object",
                },
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "type": "literal",
                        "value": null,
                      },
                    },
                    {
                      "name": "error",
                      "type": undefined,
                    },
                  ],
                  "type": "object",
                },
              ],
              "type": "union",
            },
            "name": "Promise",
            "type": "promise",
          },
        },
      },
      "@supabase/auth-js.GoTrueAdminMFAApi.listFactors": {
        "comment": {
          "examples": [
            {
              "code": "\`\`\`js
const { data, error } = await supabase.auth.admin.mfa.listFactors()
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "list-all-factors-for-a-user",
              "name": "List all factors for a user",
              "response": "\`\`\`json
{
  data: {
    factors: Factor[
      {
        id: '<ID>',
        friendly_name: 'Auth App Factor',
        factor_type: 'totp',
        status: 'verified',
        created_at: '2024-01-01T00:00:00Z',
        updated_at: '2024-01-01T00:00:00Z'
      }
    ]
  },
  error: null
}
\`\`\`",
            },
          ],
          "shortText": "Lists all factors associated to a user.",
        },
        "name": "@supabase/auth-js.GoTrueAdminMFAApi.listFactors",
        "params": [
          {
            "name": "params",
            "type": {
              "name": "AuthMFAAdminListFactorsParams",
              "properties": [
                {
                  "comment": {
                    "shortText": "ID of the user.",
                  },
                  "name": "userId",
                  "type": {
                    "name": "string",
                    "type": "intrinsic",
                  },
                },
              ],
              "type": "object",
            },
          },
        ],
        "ret": {
          "type": {
            "awaited": {
              "name": "AuthMFAAdminListFactorsResponse",
              "subTypes": [
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "name": Symbol(anonymous),
                        "properties": [
                          {
                            "comment": {
                              "shortText": "All factors attached to the user.",
                            },
                            "name": "factors",
                            "type": {
                              "elemType": {
                                "name": "Factor",
                                "properties": [
                                  {
                                    "name": "created_at",
