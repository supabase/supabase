      "@supabase/auth-js.GoTrueClient.constructor": {
        "comment": {
          "examples": [
            {
              "code": "\`\`\`ts
import { createClient } from '@supabase/supabase-js'

const supabase = createClient('https://xyzcompany.supabase.co', 'your-publishable-key')
const { data, error } = await supabase.auth.getUser()
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "using-supabase-js-recommended",
              "name": "Using supabase-js (recommended)",
              "response": undefined,
            },
            {
              "code": "\`\`\`ts
import { GoTrueClient } from '@supabase/auth-js'

const auth = new GoTrueClient({
  url: 'https://xyzcompany.supabase.co/auth/v1',
  headers: { apikey: 'your-publishable-key' },
  storageKey: 'supabase-auth',
})
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "standalone-import-for-bundle-sensitive-environments",
              "name": "Standalone import for bundle-sensitive environments",
              "response": undefined,
            },
          ],
          "shortText": "Create a new client for use in the browser.",
        },
        "name": "@supabase/auth-js.GoTrueClient.constructor",
        "params": [
          {
            "name": "options",
            "type": {
              "name": "GoTrueClientOptions",
              "properties": [
                {
                  "isOptional": true,
                  "name": "autoRefreshToken",
                  "type": {
                    "name": "boolean",
                    "type": "intrinsic",
                  },
                },
                {
                  "isOptional": true,
                  "name": "debug",
                  "type": {
                    "name": Symbol(anonymous),
                    "subTypes": [
                      {
                        "name": "boolean",
                        "type": "intrinsic",
                      },
                      {
                        "comment": undefined,
                        "name": Symbol(anonymous),
                        "params": [
                          {
                            "name": "message",
                            "type": {
                              "name": "string",
                              "type": "intrinsic",
                            },
                          },
                          {
                            "name": "args",
                            "type": {
                              "elemType": {
                                "name": "any",
                                "type": "intrinsic",
                              },
                              "name": Symbol(anonymous),
                              "type": "array",
                            },
                          },
                        ],
                        "ret": {
                          "type": {
                            "name": "void",
                            "type": "intrinsic",
                          },
                        },
                        "type": "function",
                      },
                    ],
                    "type": "union",
                  },
                },
                {
                  "comment": {
                    "examples": [
                      {
                        "code": "\`\`\`ts
detectSessionInUrl: (url, params) => {
  // Ignore Facebook OAuth redirects
  if (url.pathname === '/facebook/redirect') return false
  // Use default detection for other URLs
  return Boolean(params.access_token || params.error_description)
}
\`\`\`",
                        "data": undefined,
                        "description": undefined,
                        "id": "example-1",
                        "name": "Example 1",
                        "response": undefined,
                      },
                    ],
                    "shortText": "Set to "true" if you want to automatically detect OAuth grants in the URL and sign in the user.
Set to "false" to disable automatic detection.
Set to a function to provide custom logic for determining if a URL contains a Supabase auth callback.
The function receives the current URL and parsed parameters, and should return true if the URL
should be processed as a Supabase auth callback, or false to ignore it.

This is useful when your app uses other OAuth providers (e.g., Facebook Login) that also return
access_token in the URL fragment, which would otherwise be incorrectly intercepted by Supabase Auth.",
                  },
                  "isOptional": true,
                  "name": "detectSessionInUrl",
                  "type": {
                    "name": Symbol(anonymous),
                    "subTypes": [
                      {
                        "name": "boolean",
                        "type": "intrinsic",
                      },
                      {
                        "comment": undefined,
                        "name": Symbol(anonymous),
                        "params": [
                          {
                            "name": "url",
                            "type": {
                              "name": "URL",
                              "type": "nameOnly",
                            },
                          },
                          {
                            "name": "params",
                            "type": {
                              "keyType": {
                                "name": "string",
                                "type": "intrinsic",
                              },
                              "name": Symbol(anonymous),
                              "type": "index signature",
                              "valueType": {
                                "name": "string",
                                "type": "intrinsic",
                              },
                            },
                          },
                        ],
                        "ret": {
                          "type": {
                            "name": "boolean",
                            "type": "intrinsic",
                          },
                        },
                        "type": "function",
                      },
                    ],
                    "type": "union",
                  },
                },
                {
                  "comment": {
                    "shortText": "Opt-in flags for experimental features. These APIs may change without
notice and are disabled by default.",
                    "tags": [
                      {
                        "tag": "experimental",
                        "text": "",
                      },
                    ],
                  },
                  "isOptional": true,
                  "name": "experimental",
                  "type": {
                    "name": "ExperimentalFeatureFlags",
                    "properties": [
                      {
                        "comment": {
                          "shortText": "Enables passkey support:
  - \`auth.signInWithPasskey()\`, \`auth.registerPasskey()\`
  - \`auth.passkey.*\`
  - \`auth.admin.passkey.*\`

Defaults to \`false\`. Calling any passkey method while this flag is
disabled throws a descriptive error at call time.",
                        },
                        "isOptional": true,
                        "name": "passkey",
                        "type": {
                          "name": "boolean",
                          "type": "intrinsic",
                        },
                      },
                    ],
                    "type": "object",
                  },
                },
                {
                  "isOptional": true,
                  "name": "fetch",
                  "type": {
                    "name": "Fetch",
                    "type": "nameOnly",
                  },
                },
                {
                  "isOptional": true,
                  "name": "flowType",
                  "type": {
                    "name": "AuthFlowType",
                    "subTypes": [
                      {
                        "type": "literal",
                        "value": "implicit",
                      },
                      {
                        "type": "literal",
                        "value": "pkce",
                      },
                      undefined,
                    ],
                    "type": "union",
                  },
                },
                {
                  "comment": {
                    "shortText": "Set to "true" if there is a custom authorization header set globally.",
                    "tags": [
                      {
                        "tag": "experimental",
                        "text": "",
                      },
                    ],
                  },
                  "isOptional": true,
                  "name": "hasCustomAuthorizationHeader",
                  "type": {
                    "name": "boolean",
                    "type": "intrinsic",
                  },
                },
                {
                  "isOptional": true,
                  "name": "headers",
                  "type": {
                    "keyType": {
                      "name": "string",
                      "type": "intrinsic",
                    },
                    "name": Symbol(anonymous),
                    "type": "index signature",
                    "valueType": {
                      "name": "string",
                      "type": "intrinsic",
                    },
                  },
                },
                {
                  "comment": {
                    "shortText": "Provide your own locking mechanism based on the environment. By default
the client coordinates refreshes itself (single-flight via
\`refreshingDeferred\` + commit guard) and relies on the GoTrue server to
resolve cross-tab refresh races. Passing a custom lock opts into a
legacy path that wraps every auth operation in your supplied lock — this
path is preserved for backwards compatibility (typically React Native
\`processLock\` or Node multi-process setups).",
                  },
                  "isOptional": true,
                  "name": "lock",
                  "type": {
                    "comment": undefined,
                    "name": "LockFunc",
                    "params": [
                      {
                        "comment": {
                          "shortText": "Name of the lock to be acquired.",
                        },
                        "name": "name",
                        "type": {
                          "name": "string",
                          "type": "intrinsic",
                        },
                      },
                      {
                        "comment": {
                          "shortText": "If negative, no timeout should occur. If positive it
                      should throw an Error with an \`isAcquireTimeout\`
                      property set to true if the operation fails to be
                      acquired after this much time (ms).",
                        },
                        "name": "acquireTimeout",
                        "type": {
                          "name": "number",
                          "type": "intrinsic",
                        },
                      },
                      {
                        "comment": {
                          "shortText": "The operation to execute when the lock is acquired.",
                        },
                        "name": "fn",
                        "type": {
                          "comment": undefined,
                          "name": Symbol(anonymous),
                          "params": [],
                          "ret": {
                            "type": {
                              "awaited": {
                                "name": "R",
                                "type": "nameOnly",
                              },
                              "name": "Promise",
                              "type": "promise",
                            },
                          },
                          "type": "function",
                        },
                      },
                    ],
                    "ret": {
                      "type": {
                        "awaited": {
                          "name": "R",
                          "type": "nameOnly",
                        },
                        "name": "Promise",
                        "type": "promise",
                      },
                    },
                    "type": "function",
                  },
                },
                {
                  "comment": {
                    "shortText": "The maximum time in milliseconds to wait for acquiring the custom lock
supplied via the \`lock\` option. Only consulted when a custom \`lock\` is
passed — the default lockless path doesn't use this timeout.",
                  },
                  "isOptional": true,
                  "name": "lockAcquireTimeout",
                  "type": {
                    "name": "number",
                    "type": "intrinsic",
                  },
                },
                {
                  "isOptional": true,
                  "name": "persistSession",
                  "type": {
                    "name": "boolean",
                    "type": "intrinsic",
                  },
                },
                {
                  "comment": {
                    "shortText": "If true, skips automatic initialization in constructor. Useful for SSR
contexts where initialization timing must be controlled to prevent race
conditions with HTTP response generation.",
                  },
                  "isOptional": true,
                  "name": "skipAutoInitialize",
                  "type": {
                    "name": "boolean",
                    "type": "intrinsic",
                  },
                },
                {
                  "isOptional": true,
                  "name": "storage",
                  "type": {
                    "name": "SupportedStorage",
                    "type": "nameOnly",
                  },
                },
                {
                  "isOptional": true,
                  "name": "storageKey",
                  "type": {
                    "name": "string",
                    "type": "intrinsic",
                  },
                },
                {
                  "comment": {
                    "shortText": "If there is an error with the query, throwOnError will reject the promise by
throwing the error instead of returning it as part of a successful response.",
                  },
                  "isOptional": true,
                  "name": "throwOnError",
                  "type": {
                    "name": "boolean",
                    "type": "intrinsic",
                  },
                },
                {
                  "isOptional": true,
                  "name": "url",
                  "type": {
                    "name": "string",
                    "type": "intrinsic",
                  },
                },
                {
                  "comment": {
                    "shortText": "Stores the user object in a separate storage location from the rest of the session data. When non-null, \`storage\` will only store a JSON object containing the access and refresh token and some adjacent metadata, while \`userStorage\` will only contain the user object under the key \`storageKey + '-user'\`.

When this option is set and cookie storage is used, \`getSession()\` and other functions that load a session from the cookie store might not return back a user. It's very important to always use \`getUser()\` to fetch a user object in those scenarios.",
                    "tags": [
                      {
                        "tag": "experimental",
                        "text": "",
                      },
                    ],
                  },
                  "isOptional": true,
                  "name": "userStorage",
                  "type": {
                    "name": "SupportedStorage",
                    "type": "nameOnly",
                  },
                },
              ],
              "type": "object",
            },
          },
        ],
        "ret": {
          "type": {
            "name": "GoTrueClient",
            "type": "nameOnly",
          },
        },
      },
      "@supabase/auth-js.GoTrueClient.dispose": {
        "comment": {
          "examples": [
            {
              "code": "\`\`\`ts
useEffect(() => {
  const client = createClient(...)
  return () => { client.auth.dispose() }
}, [])
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "cleanup-on-react-unmount",
              "name": "Cleanup on React unmount",
              "response": undefined,
            },
          ],
          "shortText": "Tears down the client's background work: stops the auto-refresh interval,
removes the \`visibilitychange\` listener, closes the cross-tab
\`BroadcastChannel\`, and clears registered \`onAuthStateChange\` subscribers.

Call this from cleanup hooks when the client is being replaced before
its JS realm is destroyed. React Strict Mode and HMR are the common
cases. Any in-flight \`fetch\` calls continue to completion and may still
write to storage; dispose doesn't abort them or erase storage.

Lifecycle caveat: because in-flight refreshes are not aborted, a
disposed instance can still persist a rotated session to storage after
\`dispose()\` returns. A subsequent \`createClient\` against the same
\`storageKey\` will pick up that session on its next read. If you need
strict isolation between client lifecycles, await any pending auth
operation before calling \`dispose()\` (or change the \`storageKey\` for
the replacement client).

Safe to call repeatedly.",
        },
        "name": "@supabase/auth-js.GoTrueClient.dispose",
        "params": [],
        "ret": {
          "type": {
            "awaited": {
              "name": "void",
              "type": "intrinsic",
            },
            "name": "Promise",
            "type": "promise",
          },
        },
      },
