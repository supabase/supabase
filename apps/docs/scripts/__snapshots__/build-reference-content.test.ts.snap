      "@supabase/auth-js.GoTrueAdminApi.deleteUser": {
        "comment": {
          "examples": [
            {
              "code": "\`\`\`js
const { data, error } = await supabase.auth.admin.deleteUser(
  '715ed5db-f090-4b8c-a067-640ecee36aa0'
)
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "removes-a-user",
              "name": "Removes a user",
              "response": "\`\`\`json
{
  "data": {
    "user": {}
  },
  "error": null
}
\`\`\`",
            },
          ],
          "shortText": "Delete a user. Requires a \`service_role\` key.",
          "text": "- The \`deleteUser()\` method requires the user's ID, which maps to the \`auth.users.id\` column.",
        },
        "name": "@supabase/auth-js.GoTrueAdminApi.deleteUser",
        "params": [
          {
            "comment": {
              "shortText": "The user id you want to remove.",
            },
            "name": "id",
            "type": {
              "name": "string",
              "type": "intrinsic",
            },
          },
          {
            "comment": {
              "shortText": "If true, then the user will be soft-deleted from the auth schema. Soft deletion allows user identification from the hashed user ID but is not reversible.
Defaults to false for backward compatibility.

This function should only be called on a server. Never expose your \`service_role\` key in the browser.",
            },
            "name": "shouldSoftDelete",
            "type": {
              "name": "boolean",
              "type": "intrinsic",
            },
          },
        ],
