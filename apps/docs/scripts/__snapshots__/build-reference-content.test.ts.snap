      "@supabase/auth-js.AuthOAuthServerApi.approveAuthorization": {
        "comment": {
          "shortText": "Approves an OAuth authorization request.
Only relevant when the OAuth 2.1 server is enabled in Supabase Auth.

After approval, the user's consent is stored and an authorization code is generated.
The response contains a complete redirect URL with the authorization code and state.",
        },
        "name": "@supabase/auth-js.AuthOAuthServerApi.approveAuthorization",
        "params": [
          {
            "comment": {
              "shortText": "The authorization ID to approve",
            },
            "name": "authorizationId",
            "type": {
              "name": "string",
              "type": "intrinsic",
            },
          },
          {
            "comment": {
              "shortText": "Optional parameters",
            },
            "isOptional": true,
            "name": "options",
            "type": {
              "name": Symbol(anonymous),
              "properties": [
                {
                  "comment": {
                    "shortText": "If false (default), automatically redirects the browser to the OAuth client. If true, returns the redirect_url without automatic redirect (useful for custom handling).",
                  },
                  "isOptional": true,
                  "name": "skipBrowserRedirect",
                  "type": {
                    "name": "boolean",
                    "type": "intrinsic",
                  },
                },
              ],
              "type": "object",
            },
          },
        ],
        "ret": {
          "type": {
            "awaited": {
              "name": "AuthOAuthConsentResponse",
              "subTypes": [
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "name": "OAuthRedirect",
                        "properties": [
                          {
                            "comment": {
                              "shortText": "Complete redirect URL with authorization code and state parameters (e.g., "https://app.com/callback?code=xxx&state=yyy")",
                            },
                            "name": "redirect_url",
                            "type": {
                              "name": "string",
                              "type": "intrinsic",
                            },
                          },
                        ],
                        "type": "object",
                      },
                    },
                    {
                      "name": "error",
                      "type": {
                        "type": "literal",
                        "value": null,
                      },
                    },
                  ],
                  "type": "object",
                },
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "type": "literal",
                        "value": null,
                      },
                    },
                    {
                      "name": "error",
                      "type": undefined,
                    },
                  ],
                  "type": "object",
                },
              ],
              "type": "union",
            },
            "name": "Promise",
            "type": "promise",
          },
        },
      },
      "@supabase/auth-js.AuthOAuthServerApi.denyAuthorization": {
        "comment": {
          "shortText": "Denies an OAuth authorization request.
Only relevant when the OAuth 2.1 server is enabled in Supabase Auth.

After denial, the response contains a redirect URL with an OAuth error
(access_denied) to inform the OAuth client that the user rejected the request.",
        },
        "name": "@supabase/auth-js.AuthOAuthServerApi.denyAuthorization",
        "params": [
          {
            "comment": {
              "shortText": "The authorization ID to deny",
            },
            "name": "authorizationId",
            "type": {
              "name": "string",
              "type": "intrinsic",
            },
          },
          {
            "comment": {
              "shortText": "Optional parameters",
            },
            "isOptional": true,
            "name": "options",
            "type": {
              "name": Symbol(anonymous),
              "properties": [
                {
                  "comment": {
                    "shortText": "If false (default), automatically redirects the browser to the OAuth client. If true, returns the redirect_url without automatic redirect (useful for custom handling).",
                  },
                  "isOptional": true,
                  "name": "skipBrowserRedirect",
                  "type": {
                    "name": "boolean",
                    "type": "intrinsic",
                  },
                },
              ],
              "type": "object",
            },
          },
        ],
        "ret": {
          "type": {
            "awaited": {
              "name": "AuthOAuthConsentResponse",
              "subTypes": [
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "name": "OAuthRedirect",
                        "properties": [
                          {
                            "comment": {
                              "shortText": "Complete redirect URL with authorization code and state parameters (e.g., "https://app.com/callback?code=xxx&state=yyy")",
                            },
                            "name": "redirect_url",
                            "type": {
                              "name": "string",
                              "type": "intrinsic",
                            },
                          },
                        ],
                        "type": "object",
                      },
                    },
                    {
                      "name": "error",
                      "type": {
                        "type": "literal",
                        "value": null,
                      },
                    },
                  ],
                  "type": "object",
                },
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "type": "literal",
                        "value": null,
                      },
                    },
                    {
                      "name": "error",
                      "type": undefined,
                    },
                  ],
                  "type": "object",
                },
              ],
              "type": "union",
            },
            "name": "Promise",
            "type": "promise",
          },
        },
      },
      "@supabase/auth-js.AuthOAuthServerApi.getAuthorizationDetails": {
        "comment": {
          "shortText": "Retrieves details about an OAuth authorization request.
Used to display consent information to the user.
Only relevant when the OAuth 2.1 server is enabled in Supabase Auth.

This method returns one of two response types:
- \`OAuthAuthorizationDetails\`: User needs to consent - show consent page with client info
- \`OAuthRedirect\`: User already consented - redirect immediately to the OAuth client

Use type narrowing to distinguish between the responses:
\`\`\`typescript
if ('authorization_id' in data) {
  // Show consent page
} else {
  // Redirect to data.redirect_url
}
\`\`\`",
        },
        "name": "@supabase/auth-js.AuthOAuthServerApi.getAuthorizationDetails",
        "params": [
          {
            "comment": {
              "shortText": "The authorization ID from the authorization request",
            },
            "name": "authorizationId",
            "type": {
              "name": "string",
              "type": "intrinsic",
            },
          },
        ],
        "ret": {
          "type": {
            "awaited": {
              "name": "AuthOAuthAuthorizationDetailsResponse",
              "subTypes": [
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "name": Symbol(anonymous),
                        "subTypes": [
                          {
                            "name": "OAuthAuthorizationDetails",
                            "properties": [
                              {
                                "comment": {
                                  "shortText": "The authorization ID used to approve or deny the request",
                                },
                                "name": "authorization_id",
                                "type": {
                                  "name": "string",
                                  "type": "intrinsic",
                                },
                              },
                              {
                                "comment": {
                                  "shortText": "OAuth client requesting authorization",
                                },
                                "name": "client",
                                "type": {
                                  "name": "OAuthAuthorizationClient",
                                  "properties": [
                                    {
                                      "comment": {
                                        "shortText": "Unique identifier for the OAuth client (UUID)",
                                      },
                                      "name": "id",
                                      "type": {
                                        "name": "string",
                                        "type": "intrinsic",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "URI of the OAuth client's logo",
                                      },
                                      "name": "logo_uri",
                                      "type": {
                                        "name": "string",
                                        "type": "intrinsic",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "Human-readable name of the OAuth client",
                                      },
                                      "name": "name",
                                      "type": {
                                        "name": "string",
                                        "type": "intrinsic",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "URI of the OAuth client's website",
                                      },
                                      "name": "uri",
                                      "type": {
                                        "name": "string",
                                        "type": "intrinsic",
                                      },
                                    },
                                  ],
                                  "type": "object",
                                },
                              },
                              {
                                "comment": {
                                  "shortText": "The OAuth client's registered redirect URI (base URI without query parameters)",
                                },
                                "name": "redirect_uri",
                                "type": {
                                  "name": "string",
                                  "type": "intrinsic",
                                },
                              },
                              {
                                "comment": {
                                  "shortText": "Space-separated list of requested scopes (e.g., "openid profile email")",
                                },
                                "name": "scope",
                                "type": {
                                  "name": "string",
                                  "type": "intrinsic",
                                },
                              },
                              {
                                "comment": {
                                  "shortText": "User object associated with the authorization",
                                },
                                "name": "user",
                                "type": {
                                  "name": Symbol(anonymous),
                                  "properties": [
                                    {
                                      "comment": {
                                        "shortText": "User email",
                                      },
                                      "name": "email",
                                      "type": {
                                        "name": "string",
                                        "type": "intrinsic",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "User ID (UUID)",
                                      },
                                      "name": "id",
                                      "type": {
                                        "name": "string",
                                        "type": "intrinsic",
                                      },
                                    },
                                  ],
                                  "type": "object",
                                },
                              },
                            ],
                            "type": "object",
                          },
                          {
                            "name": "OAuthRedirect",
                            "properties": [
                              {
                                "comment": {
                                  "shortText": "Complete redirect URL with authorization code and state parameters (e.g., "https://app.com/callback?code=xxx&state=yyy")",
                                },
                                "name": "redirect_url",
                                "type": {
                                  "name": "string",
                                  "type": "intrinsic",
                                },
                              },
                            ],
                            "type": "object",
                          },
                        ],
                        "type": "union",
                      },
                    },
                    {
                      "name": "error",
                      "type": {
                        "type": "literal",
                        "value": null,
                      },
                    },
                  ],
                  "type": "object",
                },
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "type": "literal",
                        "value": null,
                      },
                    },
                    {
                      "name": "error",
                      "type": undefined,
                    },
                  ],
                  "type": "object",
                },
              ],
              "type": "union",
            },
            "name": "Promise",
            "type": "promise",
          },
        },
      },
      "@supabase/auth-js.AuthOAuthServerApi.listGrants": {
        "comment": {
          "shortText": "Lists all OAuth grants that the authenticated user has authorized.
Only relevant when the OAuth 2.1 server is enabled in Supabase Auth.",
        },
        "name": "@supabase/auth-js.AuthOAuthServerApi.listGrants",
        "params": [],
        "ret": {
          "type": {
            "awaited": {
              "name": "AuthOAuthGrantsResponse",
              "subTypes": [
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "elemType": {
                          "name": "OAuthGrant",
                          "properties": [
                            {
                              "comment": {
                                "shortText": "OAuth client information",
                              },
                              "name": "client",
                              "type": {
                                "name": "OAuthAuthorizationClient",
                                "properties": [
                                  {
                                    "comment": {
                                      "shortText": "Unique identifier for the OAuth client (UUID)",
                                    },
                                    "name": "id",
                                    "type": {
                                      "name": "string",
                                      "type": "intrinsic",
                                    },
                                  },
                                  {
                                    "comment": {
                                      "shortText": "URI of the OAuth client's logo",
                                    },
                                    "name": "logo_uri",
                                    "type": {
                                      "name": "string",
                                      "type": "intrinsic",
                                    },
                                  },
                                  {
                                    "comment": {
                                      "shortText": "Human-readable name of the OAuth client",
                                    },
                                    "name": "name",
                                    "type": {
                                      "name": "string",
                                      "type": "intrinsic",
                                    },
                                  },
                                  {
                                    "comment": {
                                      "shortText": "URI of the OAuth client's website",
                                    },
                                    "name": "uri",
                                    "type": {
                                      "name": "string",
                                      "type": "intrinsic",
                                    },
                                  },
                                ],
                                "type": "object",
                              },
                            },
                            {
                              "comment": {
                                "shortText": "Timestamp when the grant was created (ISO 8601 date-time)",
                              },
                              "name": "granted_at",
                              "type": {
                                "name": "string",
                                "type": "intrinsic",
                              },
                            },
                            {
                              "comment": {
                                "shortText": "Array of scopes granted to this client",
                              },
                              "name": "scopes",
                              "type": {
                                "elemType": {
                                  "name": "string",
                                  "type": "intrinsic",
                                },
                                "name": Symbol(anonymous),
                                "type": "array",
