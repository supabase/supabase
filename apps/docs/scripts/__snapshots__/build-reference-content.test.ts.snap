                                      "name": "string",
                                      "type": "intrinsic",
                                    },
                                  },
                                  {
                                    "comment": {
                                      "shortText": "Type of factor. \`totp\` and \`phone\` supported with this version",
                                    },
                                    "name": "factor_type",
                                    "type": {
                                      "name": "Type",
                                      "type": "nameOnly",
                                    },
                                  },
                                  {
                                    "comment": {
                                      "shortText": "Friendly name of the factor, useful to disambiguate between multiple factors.",
