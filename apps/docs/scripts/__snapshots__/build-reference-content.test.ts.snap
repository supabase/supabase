      "@supabase/auth-js.AuthPasskeyApi.verifyAuthentication": {
        "comment": {
          "shortText": "Verifies a passkey authentication credential against a previously issued
challenge. Used as the second step of a two-step sign-in flow.",
        },
        "name": "@supabase/auth-js.AuthPasskeyApi.verifyAuthentication",
        "params": [
          {
            "name": "params",
            "type": {
              "name": "VerifyPasskeyAuthenticationParams",
              "properties": [
                {
                  "comment": {
                    "shortText": "Challenge ID from startAuthentication",
                  },
                  "name": "challengeId",
                  "type": {
                    "name": "string",
                    "type": "intrinsic",
                  },
                },
                {
                  "comment": {
                    "shortText": "Serialized credential from navigator.credentials.get()",
                  },
                  "name": "credential",
                  "type": {
                    "name": "ServerCredentialResponse",
                    "type": "nameOnly",
                  },
                },
              ],
              "type": "object",
            },
          },
        ],
        "ret": {
          "type": {
            "awaited": {
              "name": "AuthPasskeyAuthenticationVerifyResponse",
              "subTypes": [
                {
                  "name": Symbol(anonymous),
                  "properties": [
                    {
                      "name": "data",
                      "type": {
                        "name": Symbol(anonymous),
                        "properties": [
                          {
                            "name": "session",
                            "type": {
                              "name": Symbol(anonymous),
                              "subTypes": [
                                {
                                  "name": "Session",
                                  "properties": [
                                    {
                                      "comment": {
                                        "shortText": "The access token jwt. It is recommended to set the JWT_EXPIRY to a shorter expiry value.",
                                      },
                                      "name": "access_token",
                                      "type": {
                                        "name": "string",
                                        "type": "intrinsic",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "A timestamp of when the token will expire. Returned when a login is confirmed.",
                                      },
                                      "isOptional": true,
                                      "name": "expires_at",
                                      "type": {
                                        "name": "number",
                                        "type": "intrinsic",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "The number of seconds until the token expires (since it was issued). Returned when a login is confirmed.",
                                      },
                                      "name": "expires_in",
                                      "type": {
                                        "name": "number",
                                        "type": "intrinsic",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "The oauth provider refresh token. If present, this can be used to refresh the provider_token via the oauth provider's API.
Not all oauth providers return a provider refresh token. If the provider_refresh_token is missing, please refer to the oauth provider's documentation for information on how to obtain the provider refresh token.",
                                      },
                                      "isOptional": true,
                                      "name": "provider_refresh_token",
                                      "type": {
                                        "name": Symbol(anonymous),
                                        "subTypes": [
                                          {
                                            "type": "literal",
                                            "value": null,
                                          },
                                          {
                                            "name": "string",
                                            "type": "intrinsic",
                                          },
                                        ],
                                        "type": "union",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "The oauth provider token. If present, this can be used to make external API requests to the oauth provider used.",
                                      },
                                      "isOptional": true,
                                      "name": "provider_token",
                                      "type": {
                                        "name": Symbol(anonymous),
                                        "subTypes": [
                                          {
                                            "type": "literal",
                                            "value": null,
                                          },
                                          {
                                            "name": "string",
                                            "type": "intrinsic",
                                          },
                                        ],
                                        "type": "union",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "A one-time used refresh token that never expires.",
                                      },
                                      "name": "refresh_token",
                                      "type": {
                                        "name": "string",
                                        "type": "intrinsic",
                                      },
                                    },
                                    {
                                      "name": "token_type",
                                      "type": {
                                        "type": "literal",
                                        "value": "bearer",
                                      },
                                    },
                                    {
                                      "comment": {
                                        "shortText": "When using a separate user storage, accessing properties of this object will throw an error.",
                                      },
                                      "name": "user",
                                      "type": {
                                        "name": "User",
                                        "properties": [
                                          {
                                            "isOptional": true,
                                            "name": "action_link",
                                            "type": {
                                              "name": "string",
                                              "type": "intrinsic",
                                            },
                                          },
                                          {
                                            "name": "app_metadata",
                                            "type": {
                                              "name": "UserAppMetadata",
                                              "properties": [
                                                {
                                                  "comment": {
                                                    "shortText": "The first provider that the user used to sign up with.",
                                                  },
                                                  "isOptional": true,
                                                  "name": "provider",
                                                  "type": {
                                                    "name": "string",
                                                    "type": "intrinsic",
                                                  },
                                                },
                                                {
                                                  "comment": {
                                                    "shortText": "A list of all providers that the user has linked to their account.",
                                                  },
                                                  "isOptional": true,
                                                  "name": "providers",
                                                  "type": {
                                                    "elemType": {
                                                      "name": "string",
                                                      "type": "intrinsic",
                                                    },
                                                    "name": Symbol(anonymous),
                                                    "type": "array",
                                                  },
                                                },
                                              ],
                                              "type": "object",
                                            },
                                          },
                                          {
                                            "name": "aud",
                                            "type": {
                                              "name": "string",
                                              "type": "intrinsic",
                                            },
                                          },
                                          {
                                            "isOptional": true,
                                            "name": "banned_until",
                                            "type": {
                                              "name": "string",
                                              "type": "intrinsic",
                                            },
                                          },
                                          {
                                            "isOptional": true,
                                            "name": "confirmation_sent_at",
                                            "type": {
                                              "name": "string",
                                              "type": "intrinsic",
                                            },
