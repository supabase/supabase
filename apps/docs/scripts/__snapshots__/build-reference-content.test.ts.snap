      "@supabase/auth-js.GoTrueClient.getUserIdentities": {
        "comment": {
          "examples": [
            {
              "code": "\`\`\`js
const { data, error } = await supabase.auth.getUserIdentities()
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "returns-a-list-of-identities-linked-to-the-user",
              "name": "Returns a list of identities linked to the user",
              "response": "\`\`\`json
