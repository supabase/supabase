                  "type": {
                    "name": "number",
                    "type": "intrinsic",
                  },
                },
                {
                  "comment": {
                    "shortText": "Number of items returned per page",
                  },
                  "isOptional": true,
                  "name": "perPage",
                  "type": {
                    "name": "number",
                    "type": "intrinsic",
                  },
                },
              ],
              "type": "object",
            },
          },
        ],
        "ret": {
