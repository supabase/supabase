      "@supabase/auth-js.GoTrueAdminApi.constructor": {
        "comment": {
          "examples": [
            {
              "code": "\`\`\`ts
import { createClient } from '@supabase/supabase-js'

const supabase = createClient('https://xyzcompany.supabase.co', 'your-secret-key')
const { data, error } = await supabase.auth.admin.listUsers()
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "using-supabase-js-recommended",
              "name": "Using supabase-js (recommended)",
              "response": undefined,
            },
            {
              "code": "\`\`\`ts
import { GoTrueAdminApi } from '@supabase/auth-js'

const admin = new GoTrueAdminApi({
  url: 'https://xyzcompany.supabase.co/auth/v1',
  headers: { Authorization: \`Bearer \${process.env.SUPABASE_SECRET_KEY}\` },
})
\`\`\`",
              "data": undefined,
              "description": undefined,
              "id": "standalone-import-for-bundle-sensitive-environments",
              "name": "Standalone import for bundle-sensitive environments",
              "response": undefined,
            },
          ],
          "shortText": "Creates an admin API client that can be used to manage users and OAuth clients.",
        },
        "name": "@supabase/auth-js.GoTrueAdminApi.constructor",
        "params": [
          {
            "name": Symbol(anonymous),
            "type": {
              "name": Symbol(anonymous),
              "properties": [
                {
                  "isOptional": true,
                  "name": "experimental",
                  "type": {
                    "name": "ExperimentalFeatureFlags",
                    "properties": [
                      {
                        "comment": {
                          "shortText": "Enables passkey support:
  - \`auth.signInWithPasskey()\`, \`auth.registerPasskey()\`
  - \`auth.passkey.*\`
  - \`auth.admin.passkey.*\`

Defaults to \`false\`. Calling any passkey method while this flag is
disabled throws a descriptive error at call time.",
                        },
                        "isOptional": true,
                        "name": "passkey",
                        "type": {
                          "name": "boolean",
                          "type": "intrinsic",
                        },
                      },
                    ],
                    "type": "object",
                  },
                },
                {
                  "isOptional": true,
                  "name": "fetch",
                  "type": {
                    "comment": {
                      "shortText": "[MDN Reference](https://developer.mozilla.org/docs/Web/API/Window/fetch)",
                    },
                    "name": Symbol(anonymous),
                    "params": [
                      {
                        "name": "input",
                        "type": {
                          "name": Symbol(anonymous),
                          "subTypes": [
                            {
                              "name": "URL",
                              "type": "nameOnly",
                            },
                            {
                              "name": "RequestInfo",
                              "type": "nameOnly",
                            },
                          ],
                          "type": "union",
                        },
                      },
                      {
                        "isOptional": true,
