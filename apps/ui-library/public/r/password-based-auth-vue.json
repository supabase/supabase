{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "password-based-auth-vue",
  "type": "registry:block",
  "title": "Password Based Auth flow for Vue and Supabase",
  "description": "Password Based Auth flow for Vue and Supabase",
  "dependencies": [
    "@supabase/supabase-js@latest"
  ],
  "registryDependencies": [
    "button",
    "card",
    "input",
    "label"
  ],
  "files": [
    {
      "path": "registry/default/password-based-auth/vue/components/login-form.vue",
      "content": "<script setup lang=\"ts\">\r\nimport { ref } from \"vue\"\r\nimport { createClient } from \"@/lib/supabase/client\"\r\nimport { Button } from \"@/components/ui/button\"\r\nimport {\r\n  Card,\r\n  CardContent,\r\n  CardDescription,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/components/ui/card\"\r\nimport { Input } from \"@/components/ui/input\"\r\nimport { Label } from \"@/components/ui/label\"\r\n\r\nconst email = ref(\"\")\r\nconst error = ref<string | null>(null)\r\nconst success = ref(false)\r\nconst isLoading = ref(false)\r\n\r\nconst handleForgotPassword = async (e: Event) => {\r\n  e.preventDefault()\r\n  const supabase = createClient()\r\n  isLoading.value = true\r\n  error.value = null\r\n\r\n  try {\r\n    const { error: supabaseError } = await supabase.auth.resetPasswordForEmail(email.value, {\r\n      redirectTo: \"http://localhost:3000/update-password\",\r\n    })\r\n    if (supabaseError) throw supabaseError\r\n    success.value = true\r\n  } catch (err: unknown) {\r\n    error.value = err instanceof Error ? err.message : \"An error occurred\"\r\n  } finally {\r\n    isLoading.value = false\r\n  }\r\n}\r\n</script>\r\n\r\n<template>\r\n  <div class=\"flex flex-col gap-6\">\r\n    <Card v-if=\"success\">\r\n      <CardHeader>\r\n        <CardTitle class=\"text-2xl\">Check Your Email</CardTitle>\r\n        <CardDescription>Password reset instructions sent</CardDescription>\r\n      </CardHeader>\r\n      <CardContent>\r\n        <p class=\"text-sm text-muted-foreground\">\r\n          If you registered using your email and password, you will receive a password reset email.\r\n        </p>\r\n      </CardContent>\r\n    </Card>\r\n\r\n    <Card v-else>\r\n      <CardHeader>\r\n        <CardTitle class=\"text-2xl\">Reset Your Password</CardTitle>\r\n        <CardDescription>\r\n          Type in your email and we&apos;ll send you a link to reset your password\r\n        </CardDescription>\r\n      </CardHeader>\r\n      <CardContent>\r\n        <form @submit=\"handleForgotPassword\">\r\n          <div class=\"flex flex-col gap-6\">\r\n            <div class=\"grid gap-2\">\r\n              <Label for=\"email\">Email</Label>\r\n              <Input\r\n                id=\"email\"\r\n                type=\"email\"\r\n                placeholder=\"m@example.com\"\r\n                required\r\n                v-model=\"email\"\r\n              />\r\n            </div>\r\n            <p v-if=\"error\" class=\"text-sm text-red-500\">{{ error }}</p>\r\n            <Button type=\"submit\" class=\"w-full\" :disabled=\"isLoading\">\r\n              {{ isLoading ? \"Sending...\" : \"Send reset email\" }}\r\n            </Button>\r\n          </div>\r\n          <div class=\"mt-4 text-center text-sm\">\r\n            Already have an account?\r\n            <a href=\"/login\" class=\"underline underline-offset-4\">Login</a>\r\n          </div>\r\n        </form>\r\n      </CardContent>\r\n    </Card>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:component",
      "target": "components/login-form.vue"
    },
    {
      "path": "registry/default/password-based-auth/vue/components/sign-up-form.vue",
      "content": "<script setup lang=\"ts\">\r\nimport { ref } from \"vue\"\r\nimport { createClient } from \"@/lib/supabase/client\"\r\nimport { Button } from \"@/components/ui/button\"\r\nimport {\r\n  Card,\r\n  CardContent,\r\n  CardDescription,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/components/ui/card\"\r\nimport { Input } from \"@/components/ui/input\"\r\nimport { Label } from \"@/components/ui/label\"\r\n\r\nconst email = ref(\"\")\r\nconst password = ref(\"\")\r\nconst repeatPassword = ref(\"\")\r\nconst error = ref<string | null>(null)\r\nconst isLoading = ref(false)\r\nconst success = ref(false)\r\n\r\nconst handleSignUp = async () => {\r\n  const supabase = createClient()\r\n  error.value = null\r\n\r\n  if (password.value !== repeatPassword.value) {\r\n    error.value = \"Passwords do not match\"\r\n    return\r\n  }\r\n\r\n  isLoading.value = true\r\n  try {\r\n    const { error: supabaseError } = await supabase.auth.signUp({\r\n      email: email.value,\r\n      password: password.value,\r\n    })\r\n    if (supabaseError) throw supabaseError\r\n    success.value = true\r\n  } catch (err: unknown) {\r\n    error.value = err instanceof Error ? err.message : \"An error occurred\"\r\n  } finally {\r\n    isLoading.value = false\r\n  }\r\n}\r\n</script>\r\n\r\n<template>\r\n  <div class=\"flex flex-col gap-6\">\r\n    <Card v-if=\"success\">\r\n      <CardHeader>\r\n        <CardTitle class=\"text-2xl\">Thank you for signing up!</CardTitle>\r\n        <CardDescription>Check your email to confirm</CardDescription>\r\n      </CardHeader>\r\n      <CardContent>\r\n        <p class=\"text-sm text-muted-foreground\">\r\n          You've successfully signed up. Please check your email to confirm your account before\r\n          signing in.\r\n        </p>\r\n      </CardContent>\r\n    </Card>\r\n\r\n    <Card v-else>\r\n      <CardHeader>\r\n        <CardTitle class=\"text-2xl\">Sign up</CardTitle>\r\n        <CardDescription>Create a new account</CardDescription>\r\n      </CardHeader>\r\n      <CardContent>\r\n        <form @submit.prevent=\"handleSignUp\">\r\n          <div class=\"flex flex-col gap-6\">\r\n            <!-- Email -->\r\n            <div class=\"grid gap-2\">\r\n              <Label for=\"email\">Email</Label>\r\n              <Input\r\n                id=\"email\"\r\n                type=\"email\"\r\n                placeholder=\"m@example.com\"\r\n                required\r\n                v-model=\"email\"\r\n              />\r\n            </div>\r\n\r\n            <!-- Password -->\r\n            <div class=\"grid gap-2\">\r\n              <div class=\"flex items-center\">\r\n                <Label for=\"password\">Password</Label>\r\n              </div>\r\n              <Input\r\n                id=\"password\"\r\n                type=\"password\"\r\n                required\r\n                v-model=\"password\"\r\n              />\r\n            </div>\r\n\r\n            <!-- Repeat Password -->\r\n            <div class=\"grid gap-2\">\r\n              <div class=\"flex items-center\">\r\n                <Label for=\"repeat-password\">Repeat Password</Label>\r\n              </div>\r\n              <Input\r\n                id=\"repeat-password\"\r\n                type=\"password\"\r\n                required\r\n                v-model=\"repeatPassword\"\r\n              />\r\n            </div>\r\n\r\n            <!-- Error -->\r\n            <p v-if=\"error\" class=\"text-sm text-red-500\">{{ error }}</p>\r\n\r\n            <!-- Submit -->\r\n            <Button type=\"submit\" class=\"w-full\" :disabled=\"isLoading\">\r\n              {{ isLoading ? \"Creating an account...\" : \"Sign up\" }}\r\n            </Button>\r\n          </div>\r\n\r\n          <div class=\"mt-4 text-center text-sm\">\r\n            Already have an account?\r\n            <a href=\"/login\" class=\"underline underline-offset-4\">Login</a>\r\n          </div>\r\n        </form>\r\n      </CardContent>\r\n    </Card>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:component",
      "target": "components/sign-up-form.vue"
    },
    {
      "path": "registry/default/password-based-auth/vue/components/forgot-password-form.vue",
      "content": "<script setup lang=\"ts\">\r\nimport { ref } from \"vue\"\r\nimport { createClient } from \"@/lib/supabase/client\"\r\nimport { Button } from \"@/components/ui/button\"\r\nimport {\r\n  Card,\r\n  CardContent,\r\n  CardDescription,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/components/ui/card\"\r\nimport { Input } from \"@/components/ui/input\"\r\nimport { Label } from \"@/components/ui/label\"\r\n\r\n\r\nconst email = ref(\"\")\r\nconst error = ref<string | null>(null)\r\nconst success = ref(false)\r\nconst isLoading = ref(false)\r\n\r\nconst handleForgotPassword = async (e: Event) => {\r\n  e.preventDefault()\r\n  const supabase = createClient()\r\n  isLoading.value = true\r\n  error.value = null\r\n\r\n  try {\r\n    const { error: supabaseError } = await supabase.auth.resetPasswordForEmail(email.value, {\r\n      redirectTo: \"http://localhost:3000/update-password\",\r\n    })\r\n    if (supabaseError) throw supabaseError\r\n    success.value = true\r\n  } catch (err: unknown) {\r\n    error.value = err instanceof Error ? err.message : \"An error occurred\"\r\n  } finally {\r\n    isLoading.value = false\r\n  }\r\n}\r\n</script>\r\n\r\n<template>\r\n  <div class=\"flex flex-col gap-6\">\r\n    <Card v-if=\"success\">\r\n      <CardHeader>\r\n        <CardTitle class=\"text-2xl\">Check Your Email</CardTitle>\r\n        <CardDescription>Password reset instructions sent</CardDescription>\r\n      </CardHeader>\r\n      <CardContent>\r\n        <p class=\"text-sm text-muted-foreground\">\r\n          If you registered using your email and password, you will receive a password reset email.\r\n        </p>\r\n      </CardContent>\r\n    </Card>\r\n\r\n    <Card v-else>\r\n      <CardHeader>\r\n        <CardTitle class=\"text-2xl\">Reset Your Password</CardTitle>\r\n        <CardDescription>\r\n          Type in your email and we&apos;ll send you a link to reset your password\r\n        </CardDescription>\r\n      </CardHeader>\r\n      <CardContent>\r\n        <form @submit=\"handleForgotPassword\">\r\n          <div class=\"flex flex-col gap-6\">\r\n            <div class=\"grid gap-2\">\r\n              <Label for=\"email\">Email</Label>\r\n              <Input\r\n                id=\"email\"\r\n                type=\"email\"\r\n                placeholder=\"m@example.com\"\r\n                required\r\n                v-model=\"email\"\r\n              />\r\n            </div>\r\n            <p v-if=\"error\" class=\"text-sm text-red-500\">{{ error }}</p>\r\n            <Button type=\"submit\" class=\"w-full\" :disabled=\"isLoading\">\r\n              {{ isLoading ? \"Sending...\" : \"Send reset email\" }}\r\n            </Button>\r\n          </div>\r\n          <div class=\"mt-4 text-center text-sm\">\r\n            Already have an account?\r\n            <a href=\"/login\" class=\"underline underline-offset-4\">Login</a>\r\n          </div>\r\n        </form>\r\n      </CardContent>\r\n    </Card>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:component",
      "target": "components/forgot-password-form.vue"
    },
    {
      "path": "registry/default/password-based-auth/vue/components/update-password-form.vue",
      "content": "<script setup lang=\"ts\">\r\nimport { ref } from \"vue\"\r\nimport { createClient } from \"@/lib/supabase/client\"\r\nimport { Button } from \"@/components/ui/button\"\r\nimport {\r\n  Card,\r\n  CardContent,\r\n  CardDescription,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/components/ui/card\"\r\nimport { Input } from \"@/components/ui/input\"\r\nimport { Label } from \"@/components/ui/label\"\r\n\r\nconst password = ref(\"\")\r\nconst error = ref<string | null>(null)\r\nconst isLoading = ref(false)\r\n\r\nconst handleUpdatePassword = async () => {\r\n  const supabase = createClient()\r\n  isLoading.value = true\r\n  error.value = null\r\n\r\n  try {\r\n    const { error: supabaseError } = await supabase.auth.updateUser({\r\n      password: password.value,\r\n    })\r\n    if (supabaseError) throw supabaseError\r\n    // Redirect user after successful password update\r\n    location.href = \"/protected\"\r\n  } catch (err: unknown) {\r\n    error.value = err instanceof Error ? err.message : \"An error occurred\"\r\n  } finally {\r\n    isLoading.value = false\r\n  }\r\n}\r\n</script>\r\n\r\n<template>\r\n  <div class=\"flex flex-col gap-6\">\r\n    <Card>\r\n      <CardHeader>\r\n        <CardTitle class=\"text-2xl\">Reset Your Password</CardTitle>\r\n        <CardDescription>Please enter your new password below.</CardDescription>\r\n      </CardHeader>\r\n      <CardContent>\r\n        <form @submit.prevent=\"handleUpdatePassword\">\r\n          <div class=\"flex flex-col gap-6\">\r\n            <div class=\"grid gap-2\">\r\n              <Label for=\"password\">New password</Label>\r\n              <Input\r\n                id=\"password\"\r\n                type=\"password\"\r\n                placeholder=\"New password\"\r\n                required\r\n                v-model=\"password\"\r\n              />\r\n            </div>\r\n            <p v-if=\"error\" class=\"text-sm text-red-500\">{{ error }}</p>\r\n            <Button type=\"submit\" class=\"w-full\" :disabled=\"isLoading\">\r\n              {{ isLoading ? \"Saving...\" : \"Save new password\" }}\r\n            </Button>\r\n          </div>\r\n        </form>\r\n      </CardContent>\r\n    </Card>\r\n  </div>\r\n</template>\r\n",
      "type": "registry:component",
      "target": "components/update-password-form.vue"
    }
  ]
}