{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "gotrue-auth-reliability",
  "title": "GoTrue / Auth Reliability",
  "tags": ["supabase", "gotrue", "auth", "reliability"],
  "schemaVersion": 39,
  "timezone": "",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Auth — Deep probe verdict",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FROZEN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "OK",     "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",   "value": null },
            { "color": "green", "value": 1 }
          ] }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(gotrue_probe_all_ok) OR on() vector(0)",
          "instant": true,
          "legendFormat": ""
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Oldest in-flight handler (s)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "orange", "value": 15 },
            { "color": "red",    "value": 30 }
          ] }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(gotrue_handler_inflight_oldest_seconds) OR on() vector(0)",
          "instant": true
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "DB pool utilisation",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "orange", "value": 0.85 },
            { "color": "red",    "value": 0.95 }
          ] }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(gotrue_db_pool_in_use) / sum(gotrue_db_pool_max)",
          "instant": true
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Goroutines",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(gotrue_goroutines)",
          "instant": true
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "POST /token latency (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } },
      "targets": [
        {
          "refId": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gotrue_http_request_duration_seconds_bucket{route=\"/token\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gotrue_http_request_duration_seconds_bucket{route=\"/token\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gotrue_http_request_duration_seconds_bucket{route=\"/token\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "DB pool — in_use / idle / max",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "none" } }
        }
      },
      "targets": [
        {
          "refId": "in_use",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(gotrue_db_pool_in_use)",
          "legendFormat": "in_use"
        },
        {
          "refId": "idle",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(gotrue_db_pool_idle)",
          "legendFormat": "idle"
        },
        {
          "refId": "max",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(gotrue_db_pool_max)",
          "legendFormat": "max"
        }
      ]
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "DB pool acquire wait (p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gotrue_db_pool_acquire_wait_seconds_bucket[5m])))",
          "legendFormat": "p99 acquire wait"
        }
      ]
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Per-layer probe latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, layer) (rate(gotrue_probe_layer_latency_seconds_bucket[5m])))",
          "legendFormat": "{{layer}} p95"
        }
      ]
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "Probe failures by layer (rate / 5m)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (layer, reason) (rate(gotrue_probe_layer_fail_total[5m]))",
          "legendFormat": "{{layer}} / {{reason}}"
        }
      ]
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Panics recovered (rate / 5m)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(gotrue_panic_recovered_total[5m])",
          "legendFormat": "panics/s"
        }
      ]
    }

  ]
}
