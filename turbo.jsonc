{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**/*", "!.next/dev/**/*"],
    },
    "lint": {
      "outputs": [],
    },
    "clean": {
      "outputs": [],
      "cache": false,
    },
    "dev": {
      "cache": false,
    },
    "test": {
      "cache": false,
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
    },
  },
}
