{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "storage-avatars",
  "type": "registry:item",
  "title": "Avatar Uploads",
  "description": "Public avatar bucket with user-owned upload policies",
  "categories": [
    "Storage"
  ],
  "registryDependencies": [
    "supabase/supabase/storage",
    "supabase/supabase/auth"
  ],
  "files": [
    {
      "path": "supabase/schemas/storage.sql",
      "type": "registry:file",
      "target": "~/supabase/schemas/storage.sql"
    }
  ],
  "meta": {
    "version": "1.0.0",
    "tags": [
      "storage",
      "avatars",
      "images"
    ],
    "category": "Storage",
    "dependencies": {
      "required": [
        "storage",
        "auth"
      ],
      "optional": [
        "auth-email"
      ]
    }
  }
}
