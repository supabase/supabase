      "type": "registry:file",
      "target": "~/supabase/config.toml"
    }
  ],
  "meta": {
    "version": "1.0.0",
    "tags": [
      "api",
      "rest",
      "postgrest"
    ],
    "category": "API",
    "dependencies": {
      "required": [
        "database"
      ]
    }
  }
}
