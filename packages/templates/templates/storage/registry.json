{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "storage",
  "type": "registry:item",
  "title": "Storage",
  "description": "S3-compatible object storage for files",
  "categories": [
    "Core"
  ],
  "registryDependencies": [
    "supabase/supabase/database"
  ],
  "files": [
    {
      "path": "supabase/config.toml",
      "type": "registry:file",
      "target": "~/supabase/config.toml"
    }
  ],
  "meta": {
    "version": "1.0.0",
    "tags": [
      "storage",
      "files",
      "s3"
    ],
    "category": "Core",
    "dependencies": {
      "required": [
        "database"
      ]
    }
  }
}
